# Copy to `.env` and fill in. Values already in the shell environment take
# precedence over values in this file.

# MongoDB connection.
LEDGER_MONGO_URI=mongodb://127.0.0.1:27017
LEDGER_DB_NAME=ledger

# HTTP API bind address. 8080 is often reserved on Windows (Hyper-V/WSL).
LEDGER_HTTP_ADDR=127.0.0.1:3030

# JWT signing secret. REQUIRED in production: use a long random string, e.g.
#   openssl rand -base64 64
# Leaving this unset boots an ephemeral random secret (dev only; tokens
# invalidate on every restart and a warning is logged).
LEDGER_JWT_SECRET=

# Log level / filter for tracing-subscriber's EnvFilter syntax.
LEDGER_LOG=info,tower_http=info

# Optional: load a specific env file instead of the auto-discovered one.
# LEDGER_ENV_FILE=/absolute/path/to/custom.env
